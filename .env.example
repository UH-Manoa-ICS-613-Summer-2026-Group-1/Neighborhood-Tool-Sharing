# Copy this file to a new file named '.env' 
# and fill in your secrets.

# You can use backend/secret_key_generator.py to generate a secure random key
SECRET_KEY=put_your_generated_secret_key_here

# For PostgreSQL connection, leave the username,
# password, and database name as is for local development
DB_USER=db_username
DB_PASSWORD=db_password
DB_NAME=tool_share_db